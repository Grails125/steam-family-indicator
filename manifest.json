{
  "manifest_version": 3,
  "name": "Steam家庭库指示器",
  "version": "3.1",
  "description": "通过 Steam API 获取家庭共享库",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://api.steampowered.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/*"],
      "js": ["content_scripts/store.js"],
      "css": ["styles.css"]
    }
  ]
}
